# =============================================================================
# Portfolio — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ── Site Metadata ──────────────────────────────────────────────────────────
SITE_NAME="Your Name"
SITE_ROLE="Full Stack Developer"
SITE_LOCATION="Remote · GMT+8"
SITE_EMAIL="hello@yourdomain.com"

# ── Social Links ───────────────────────────────────────────────────────────
SITE_GITHUB_URL=https://github.com/yourusername
SITE_LINKEDIN_URL=https://linkedin.com/in/yourusername
SITE_TWITTER_URL=https://twitter.com/yourusername
SITE_FACEBOOK_URL=https://facebook.com/yourusername
SITE_INSTAGRAM_URL=https://instagram.com/yourusername

# ── EmailJS (contact form) ────────────────────────────────────────────────
# 1. Create an account at https://www.emailjs.com
# 2. Add an email service and copy its ID
# 3. Create an email template and copy its ID
# 4. Copy your Public Key from Account > API Keys
# 5. (Optional) Copy your Private Key for server-side auth
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key

# ── Google reCAPTCHA v2 (spam protection for contact form) ────────────────
# 1. Go to https://www.google.com/recaptcha/admin
# 2. Register a new site → reCAPTCHA v2 → "I'm not a robot" Checkbox
# 3. Add your domain (use "localhost" for local dev)
# 4. Copy the Site Key and paste it below
# 5. In EmailJS dashboard → Template → Settings → enable reCAPTCHA V2 → paste the Secret Key
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_v2_site_key

# ── GitHub (repos & contributions) ────────────────────────────────────────
# Create a classic Personal Access Token at:
# https://github.com/settings/tokens (no scopes needed for public repos)
NEXT_PUBLIC_GITHUB_USERNAME=your_github_username
GITHUB_USERNAME=your_github_username
GITHUB_TOKEN=your_github_personal_access_token
